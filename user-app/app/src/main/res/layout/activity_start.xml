<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:fitsSystemWindows="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Profile Switch Card (Child ↔ Parent) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_profile_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_switch_child_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_child_mode"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:checked="false"
                android:contentDescription="@string/content_desc_profile_switch" />

            <TextView
                android:id="@+id/tv_switch_parent_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_parent_mode"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Pink pastel blob top-left -->
    <View
        android:id="@+id/blob_pink"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_pastel_blob_pink"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-50dp"
        android:translationY="-50dp" />

    <!-- Green pastel blob bottom-left -->
    <View
        android:id="@+id/blob_green"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_pastel_blob_green"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-40dp"
        android:translationY="40dp" />

    <!-- Yellow triangle bottom-right -->
    <ImageView
        android:id="@+id/blob_yellow"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/bg_pastel_triangle_yellow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="20dp"
        android:translationY="20dp"
        android:contentDescription="Decorative shape" />

    <!-- Grow21 Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_grow21"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Fun Learning Subtitle -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/subtitle_fun_learning"
        android:textSize="18sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Greeting Text -->
    <TextView
        android:id="@+id/tv_greeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/greeting_format"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mascot Image -->
    <ImageView
        android:id="@+id/iv_mascot"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="60dp"
        android:src="@drawable/mascot"
        android:scaleType="centerInside"
        android:tag="mascot_image"
        android:contentDescription="App mascot"
        app:layout_constraintTop_toBottomOf="@id/tv_greeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- START Button -->
    <Button
        android:id="@+id/btn_start"
        android:layout_width="200dp"
        android:layout_height="64dp"
        android:layout_marginBottom="80dp"
        android:background="@drawable/bg_rounded_button"
        android:backgroundTint="@null"
        android:stateListAnimator="@null"
        android:text="@string/btn_start"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

