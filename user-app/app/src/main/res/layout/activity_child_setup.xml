<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:fitsSystemWindows="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_setup_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_child_setup"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Name EditText -->
    <EditText
        android:id="@+id/et_child_name"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_edittext_rounded"
        android:hint="@string/hint_child_name"
        android:inputType="textPersonName"
        android:textSize="18sp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorSecondary"
        app:layout_constraintTop_toBottomOf="@id/tv_setup_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Age Label -->
    <TextView
        android:id="@+id/tv_age_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_age"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/et_child_name"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Age Selector Row -->
    <LinearLayout
        android:id="@+id/layout_age_selector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_age_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_age_minus"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="−"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/bg_option_card_default"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/tv_age_value"
            android:layout_width="80dp"
            android:layout_height="56dp"
            android:text="5"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btn_age_plus"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="+"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/bg_option_card_default"
            android:textColor="?android:attr/textColorPrimary" />
    </LinearLayout>

    <!-- Avatar Selection Label -->
    <TextView
        android:id="@+id/tv_avatar_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_select_avatar"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/layout_age_selector"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Avatar Row -->
    <LinearLayout
        android:id="@+id/layout_avatars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_avatar_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/avatar_1"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_pastel_blob_pink"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:contentDescription="Avatar 1" />

        <ImageView
            android:id="@+id/avatar_2"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_pastel_blob_green"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:contentDescription="Avatar 2" />

        <ImageView
            android:id="@+id/avatar_3"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_skill_card_brain"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:contentDescription="Avatar 3" />

        <ImageView
            android:id="@+id/avatar_4"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_skill_card_puzzles"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:contentDescription="Avatar 4" />
    </LinearLayout>

    <!-- Save Button -->
    <Button
        android:id="@+id/btn_save_child"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_button_primary"
        android:backgroundTint="@null"
        android:stateListAnimator="@null"
        android:text="@string/btn_save"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

