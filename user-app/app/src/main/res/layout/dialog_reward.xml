<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:gravity="center_horizontal"
    android:padding="32dp">

    <TextView
        android:id="@+id/tv_reward_emoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐"
        android:textSize="64sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_reward_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reward_correct_title"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextDark"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_reward_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reward_correct_message"
        android:textSize="16sp"
        android:textColor="@color/colorTextGrey"
        android:gravity="center"
        android:layout_marginBottom="28dp" />

    <Button
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_btn_done_gradient"
        android:backgroundTint="@null"
        android:stateListAnimator="@null"
        android:text="@string/btn_next"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false" />
</LinearLayout>
